    %bf = arith.constant dense<[0.000000000e+00, 0.000000000e+00, 0.000000000e+00, 0.000000000e+00, 0.000000000e+00, 0.000000000e+00, 0.000000000e+00, 0.000000000e+00, 0.000000000e+00, 0.000000000e+00]> : tensor<10xf32>

    %flat_input = tensor.collapse_shape %input [[0, 1, 2, 3]]
        : tensor<1x3x16x16xf32> into tensor<768xf32>

    %layer1 = linalg.matvec
        ins(%w1_fused, %flat_input : tensor<256x768xf32>, tensor<768xf32>)
        outs(%b1_fused : tensor<256xf32>) -> tensor<256xf32>
    %layer1_barrier_empty = tensor.empty() : tensor<256xf32>
    %layer1_barrier = tensor.insert_slice %layer1 into %layer1_barrier_empty[0] [256] [1]
        : tensor<256xf32> into tensor<256xf32>
    %sq1_empty = tensor.empty() : tensor<256xf32>
    %sq1 = linalg.generic {
        indexing_maps = [#map1d, #map1d],
        iterator_types = ["parallel"]}
        ins(%layer1_barrier : tensor<256xf32>)
        outs(%sq1_empty : tensor<256xf32>) {
    ^bb0(%in: f32, %out: f32):
      %mul = arith.mulf %in, %in : f32
      linalg.yield %mul : f32
    } -> tensor<256xf32>

    %layer2 = linalg.matvec
        ins(%w2_fused, %sq1 : tensor<128x256xf32>, tensor<256xf32>)
        outs(%b2_fused : tensor<128xf32>) -> tensor<128xf32>
    %layer2_barrier_empty = tensor.empty() : tensor<128xf32>
    %layer2_barrier = tensor.insert_slice %layer2 into %layer2_barrier_empty[0] [128] [1]
        : tensor<128xf32> into tensor<128xf32>
    %sq2_empty = tensor.empty() : tensor<128xf32>
    %sq2 = linalg.generic {
        indexing_maps = [#map1d, #map1d],
        iterator_types = ["parallel"]}
        ins(%layer2_barrier : tensor<128xf32>)
        outs(%sq2_empty : tensor<128xf32>) {
    ^bb0(%in: f32, %out: f32):
      %mul = arith.mulf %in, %in : f32
      linalg.yield %mul : f32
    } -> tensor<128xf32>

    %layer3 = linalg.matvec
        ins(%w3_fused, %sq2 : tensor<64x128xf32>, tensor<128xf32>)
        outs(%b3_fused : tensor<64xf32>) -> tensor<64xf32>
    %layer3_barrier_empty = tensor.empty() : tensor<64xf32>
    %layer3_barrier = tensor.insert_slice %layer3 into %layer3_barrier_empty[0] [64] [1]
        : tensor<64xf32> into tensor<64xf32>
    %sq3_empty = tensor.empty() : tensor<64xf32>
    %sq3 = linalg.generic {
        indexing_maps = [#map1d, #map1d],
        iterator_types = ["parallel"]}
        ins(%layer3_barrier : tensor<64xf32>)
        outs(%sq3_empty : tensor<64xf32>) {
    ^bb0(%in: f32, %out: f32):
      %mul = arith.mulf %in, %in : f32
      linalg.yield %mul : f32
    } -> tensor<64xf32>

    %logits = linalg.matvec
        ins(%wf, %sq3 : tensor<10x64xf32>, tensor<64xf32>)
        outs(%bf : tensor<10xf32>) -> tensor<10xf32>
    return %logits : tensor<10xf32>
  }
